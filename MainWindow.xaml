<Window x:Class="Quick_Task_Tracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Quick_Task_Tracker"
        mc:Ignorable="d"
        Title="Quick-Task Tracker" Height="450" Width="800">
    <StackPanel Margin="20">
        <TextBlock Text="Quick-Task Tracker" Foreground="Black" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <DockPanel LastChildFill="True" Margin="0,0,0,20">
            <Button x:Name="AddButton" Content="Add Task" IsEnabled="false" DockPanel.Dock="Right"
                    Width="80" Click="AddButton_Click"/>
            <Button x:Name="DeleteButton" Content="Delete Selected"
                    Background="Salmon" Width="100" Click="DeleteButton_Click" Visibility="Collapsed"/>
            <ComboBox x:Name="PriorityDropdown" Width="80" Margin="0,0,5,0" SelectedIndex="0">
                <ComboBoxItem Content="Low"/>
                <ComboBoxItem Content="Medium"/>
                <ComboBoxItem Content="High"/>
            </ComboBox>
            <TextBox x:Name="TaskInput" TextChanged="TaskInput_TextChanged" KeyDown="TaskInput_KeyDown" Margin="0,0,10,0" Padding="5"/>
        </DockPanel>

        <ListBox x:Name="TaskListBox" Height="200" SelectionChanged="TaskListBox_SelectionChanged"/>
    </StackPanel>
</Window>
